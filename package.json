{
  "name": "sport-coach-mesh-analysis",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop app that compares your athletic technique to a professional's using 3D pose estimation.",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c magenta,cyan \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && node scripts/postbuild-electron.mjs && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node scripts/postbuild-electron.mjs",
    "start": "cross-env NODE_ENV=production electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p renderer/tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "better-sqlite3": "^11.3.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.sportcoach.mesh",
    "productName": "Sport Coach Mesh",
    "files": [
      "dist/**",
      "dist-electron/**",
      "node_modules/**"
    ],
    "directories": {
      "output": "release"
    }
  }
}
